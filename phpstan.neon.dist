includes:
	- phpstan-baseline.neon

parameters:
	level: 8
	phpVersion: 80000
	paths:
		- oversio-agent-abilities.php
		- includes
		- uninstall.php
	bootstrapFiles:
		- vendor/autoload.php
		- tests/phpstan-bootstrap.php
		- tests/phpstan-stubs.php
	scanDirectories:
		- vendor/wordpress/mcp-adapter
	excludePaths:
		- wp/*
		- tests/*
		- vendor/*
	treatPhpDocTypesAsCertain: false
	reportUnmatchedIgnoredErrors: false
