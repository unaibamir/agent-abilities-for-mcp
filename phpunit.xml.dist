<?xml version="1.0"?>
<phpunit
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
	bootstrap="tests/bootstrap.php"
	colors="true"
	beStrictAboutOutputDuringTests="true"
	failOnWarning="true"
	failOnRisky="true"
	cacheResultFile=".phpunit.cache/test-results"
	convertDeprecationsToExceptions="true">
	<testsuites>
		<testsuite name="unit">
			<directory>tests/unit</directory>
		</testsuite>
		<testsuite name="integration">
			<directory>tests/abilities</directory>
			<directory>tests/audit</directory>
			<directory>tests/admin</directory>
			<directory>tests/oauth</directory>
			<directory>tests/coexistence</directory>
		</testsuite>
	</testsuites>
	<!--
	  The contract suite (tests/contract, @group contract) runs against real vendor plugins under
	  its own config (phpunit-contract.xml.dist) and CI job. Exclude it here so the fast stub-based
	  suite never tries to run it, even if pointed at tests/contract directly.
	-->
	<groups>
		<exclude>
			<group>contract</group>
		</exclude>
	</groups>
	<coverage>
		<include>
			<directory suffix=".php">includes</directory>
		</include>
	</coverage>
</phpunit>
